// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  output     = "../node_modules/.prisma/client"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth.js required tables ───────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Application tables ─────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  goals         Goal[]
  annualPlans   AnnualPlan[]
  weeklyReviews WeeklyReview[]
  planGenLogs   PlanGenerationLog[]

  @@map("users")
}

model Goal {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?    @db.Text
  category    String
  deadline    DateTime?
  status      GoalStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  annualPlans        AnnualPlan[]
  planGenerationLogs PlanGenerationLog[]

  @@map("goals")
}

model AnnualPlan {
  id        String   @id @default(cuid())
  userId    String
  goalId    String?
  year      Int
  title     String
  summary   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal       Goal?                @relation(fields: [goalId], references: [id], onDelete: SetNull)
  milestones QuarterlyMilestone[]

  @@map("annual_plans")
}

model QuarterlyMilestone {
  id           String    @id @default(cuid())
  annualPlanId String
  quarter      Int
  title        String
  description  String?   @db.Text
  targetDate   DateTime?
  completed    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  annualPlan  AnnualPlan   @relation(fields: [annualPlanId], references: [id], onDelete: Cascade)
  weeklyTasks WeeklyTask[]

  @@map("quarterly_milestones")
}

model WeeklyTask {
  id          String   @id @default(cuid())
  milestoneId String?
  title       String
  description String?  @db.Text
  weekStart   DateTime
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  milestone   QuarterlyMilestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  dailyHabits DailyHabit[]

  @@map("weekly_tasks")
}

model DailyHabit {
  id           String   @id @default(cuid())
  weeklyTaskId String?
  title        String
  description  String?  @db.Text
  frequency    String   @default("daily")
  date         DateTime
  completed    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  weeklyTask WeeklyTask? @relation(fields: [weeklyTaskId], references: [id], onDelete: SetNull)

  @@map("daily_habits")
}

model WeeklyReview {
  id           String   @id @default(cuid())
  userId       String
  weekStart    DateTime
  weekEnd      DateTime
  wins         String?  @db.Text
  challenges   String?  @db.Text
  nextWeekPlan String?  @db.Text
  rating       Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("weekly_reviews")
}

model PlanGenerationLog {
  id        String   @id @default(cuid())
  userId    String
  goalId    String?
  prompt    String   @db.Text
  response  String   @db.Text
  model     String
  tokensIn  Int      @default(0)
  tokensOut Int      @default(0)
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal Goal? @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@map("plan_generation_logs")
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
}
