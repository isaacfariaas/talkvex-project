# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/metas_db?schema=public"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# Claude AI (required for plan generation)
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Optional: Rate Limiting (Upstash Redis)
# If not configured, rate limiting will be disabled
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Optional: OAuth providers
# GITHUB_ID=""
# GITHUB_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Email Service Configuration
# Provider options: console (logs to console), smtp, sendgrid, resend, ses
EMAIL_PROVIDER="console"
EMAIL_FROM="noreply@talkvex.com"

# SMTP Configuration (if EMAIL_PROVIDER=smtp)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="your-smtp-username"
# SMTP_PASS="your-smtp-password"

# SendGrid Configuration (if EMAIL_PROVIDER=sendgrid)
# SENDGRID_API_KEY="your-sendgrid-api-key"

# Resend Configuration (if EMAIL_PROVIDER=resend)
# RESEND_API_KEY="your-resend-api-key"

# AWS SES Configuration (if EMAIL_PROVIDER=ses)
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="your-aws-access-key"
# AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
